<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:keepScreenOn="true">

    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:resize_mode="fit"
        app:show_buffering="always"
        app:controller_layout_id="@layout/exo_player_control_view"
        app:show_timeout="3500"
        app:auto_show="true"
        app:use_controller="true" />

    <!-- Gesture feedback (brightness / volume / seek) -->
    <TextView
        android:id="@+id/gesture_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/player_gesture_bg"
        android:paddingHorizontal="20dp"
        android:paddingVertical="14dp"
        android:textColor="@color/player_text"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Buffering / next-episode resolving spinner -->
    <ProgressBar
        android:id="@+id/loading_spinner"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/player_accent"
        android:visibility="gone" />

    <!-- P2P resolve overlay: shown from the moment the player opens for a
         magnet-backed stream until the URL resolves (or fails). Replaces the
         old bottom-right web toast with an in-player, branded status. -->
    <LinearLayout
        android:id="@+id/resolve_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@android:color/black"
        android:visibility="gone"
        android:alpha="0">

        <ProgressBar
            android:id="@+id/resolve_spinner"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminateTint="@color/player_accent" />

        <TextView
            android:id="@+id/resolve_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:textColor="@color/player_text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:gravity="center"
            android:paddingHorizontal="32dp" />

        <TextView
            android:id="@+id/resolve_stage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/player_text_dim"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingHorizontal="32dp"
            android:text="Connecting…" />

        <LinearLayout
            android:id="@+id/resolve_error_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="22dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/resolve_retry"
                style="@style/PlayerPillButton"
                android:background="@drawable/player_pill_accent"
                android:text="Retry" />

            <TextView
                android:id="@+id/resolve_close"
                style="@style/PlayerPillButton"
                android:text="Close" />
        </LinearLayout>
    </LinearLayout>

    <!-- Auto-play next episode countdown -->
    <LinearLayout
        android:id="@+id/next_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="28dp"
        android:orientation="vertical"
        android:background="@color/player_panel"
        android:padding="18dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/next_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/player_text"
            android:textSize="15sp"
            android:text="Next episode in 10s" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/next_cancel"
                style="@style/PlayerPillButton"
                android:text="Cancel" />

            <TextView
                android:id="@+id/next_play"
                style="@style/PlayerPillButton"
                android:background="@drawable/player_pill_accent"
                android:text="Play now" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
