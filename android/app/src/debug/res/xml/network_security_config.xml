<?xml version="1.0" encoding="utf-8"?>
<!-- Debug-only override: allows cleartext HTTP to any host so the Metro
     dev server (LAN IP, not just loopback) can be reached during
     development. Release builds use the strict loopback-only config in
     src/main/res/xml/network_security_config.xml. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
