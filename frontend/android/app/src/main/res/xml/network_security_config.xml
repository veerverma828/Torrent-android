<?xml version="1.0" encoding="utf-8"?>
<!-- Allow cleartext only to the loopback TorrServer subprocess; everything
     else stays HTTPS-only. Without this, Android silently blocks any plain
     http:// request to 127.0.0.1 (API 28+ default) — both our own readiness
     probe and ExoPlayer's fetch of the stream URL need this exemption. -->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
